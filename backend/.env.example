# ---- Base de datos ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/asistenciaapp

# ---- Seguridad ----
JWT_SECRETO=cambia_esta_clave_en_produccion
# Clave de cifrado AES-256 para plantillas biometricas (64 caracteres hex = 32 bytes)
CLAVE_CIFRADO=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- Servidor ----
PUERTO=4000
URL_FRONTEND=http://localhost:5173

# ---- Correo (si se deja vacio, los correos se imprimen en consola) ----
CORREO_HOST=
CORREO_PUERTO=587
CORREO_USUARIO=
CORREO_CONTRASENA=
CORREO_REMITENTE="AsistenciaApp <no-responder@asistenciaapp.co>"
